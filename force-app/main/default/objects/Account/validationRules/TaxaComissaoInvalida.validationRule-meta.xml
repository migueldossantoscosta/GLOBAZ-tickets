<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TaxaComissaoInvalida</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT(ISBLANK(TaxaComissao__c)),
  OR(
    TaxaComissao__c &lt; 0,
    TaxaComissao__c &gt; 100
  )
)</errorConditionFormula>
    <errorDisplayField>TaxaComissao__c</errorDisplayField>
    <errorMessage>A Taxa de Comissão deve estar entre 0% e 100%</errorMessage>
</ValidationRule>
