<apex:page showHeader="false" sidebar="false" standardStylesheets="false"
             docType="html-5.0" applyHtmlTag="false" applyBodyTag="false"
             controller="GlobazSiteLoginController" title="Login">
  <html lang="pt">
  <head>
      <meta charset="UTF-8"/>
      <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
      <title>Login — Globaz Tickets</title>
      <style>
          :root{--bg:#050816;--surface:rgba(255,255,255,.05);--border:rgba(255,255,255,.10);--text:#f8fbff;--muted:rgba(255,255,255,.70);--blue:#5ea2ff;--blue2:#2563eb;--glow:0 20px 60px
  rgba(37,99,235,0.25);--radius:24px;}
          body{margin:0;font-family:Arial,sans-serif;color:var(--text);background:radial-gradient(circle at 10% 0%,rgba(50,120,255,.24),transparent 28%),radial-gradient(circle at 100%
  10%,rgba(168,85,247,.14),transparent 24%),linear-gradient(180deg,#030611 0%,#081121 40%,#050816 100%);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px 20px;}
          .card{width:100%;max-width:480px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);border-radius:24px;box-shadow:0 20px 50px
  rgba(0,0,0,.28);backdrop-filter:blur(16px);padding:42px 36px;}
          .brand{display:flex;align-items:center;gap:14px;margin-bottom:30px;justify-content:center;}
          .brand-mark{width:42px;height:42px;border-radius:14px;background:linear-gradient(135deg,rgba(94,162,255,.95),rgba(37,99,235,.80));box-shadow:var(--glow);}
          .brand-text strong{display:block;font-size:20px;letter-spacing:.8px;color:#fff;}
          .brand-text span{font-size:11px;color:var(--muted);text-transform:uppercase;}
          .eyebrow{display:inline-block;padding:8px 14px;border-radius:999px;background:rgba(94,162,255,0.14);border:1px solid
  rgba(94,162,255,0.28);color:#dcedff;font-size:12px;text-transform:uppercase;font-weight:700;margin-bottom:18px;}
          .title{font-size:36px;line-height:1;font-weight:900;margin-bottom:8px;text-align:center;}
          .copy{font-size:14px;line-height:1.6;color:var(--muted);text-align:center;margin-bottom:24px;}
          .field{display:flex;flex-direction:column;gap:8px;margin-bottom:16px;}
          .field label{font-size:12px;text-transform:uppercase;letter-spacing:.8px;font-weight:700;color:rgba(255,255,255,.62);}
          .input{width:100%;height:52px;border-radius:16px;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.06);color:#fff;padding:0 14px;box-sizing:border-box;}

  .btn{width:100%;height:54px;border:none;border-radius:16px;background:linear-gradient(135deg,var(--blue),var(--blue2));color:#fff;font-weight:800;font-size:15px;cursor:pointer;box-shadow:var(--glow);}
          .links{margin-top:18px;display:flex;justify-content:space-between;gap:16px;font-size:13px;}
          .links a{color:rgba(255,255,255,.78);text-decoration:none;}
      </style>
  </head>
  <body>
      <div class="card">
          <div class="brand">
              <div class="brand-mark"></div>
              <div class="brand-text">
                  <strong>GLOBAZ TICKETS</strong>
                  <span>premium ticketing experience</span>
              </div>
          </div>
          <div class="eyebrow">Entrar</div>
          <div class="title">Bem-vindo de volta</div>
          <div class="copy">Faz login para acederes à tua conta.</div>
          <apex:form forceSSL="true">
              <div class="field">
                  <label>Email</label>
                  <apex:inputText value="{!email}" required="true" styleClass="input"/>
              </div>
              <div class="field">
                  <label>Password</label>
                  <apex:inputSecret value="{!password}" required="true" styleClass="input"/>
              </div>
              <apex:commandButton action="{!login}" value="Entrar" styleClass="btn"/>
              <div class="links">
                  <a href="/apex/SiteRegister">Criar conta</a>
                  <a href="/globaztickets">Voltar</a>
              </div>
          </apex:form>
      </div>
      <script>
          // Guarda UID no localStorage
          var urlParams = new URLSearchParams(window.location.search);
          var uid = urlParams.get('uid');
          if (uid) {
              localStorage.setItem('globaz_uid', uid);
              window.history.replaceState({}, '', window.location.pathname);
              setTimeout(function() { window.location.href = '/apex/HomeEventos'; }, 300);
          }
      </script>
  </body>
  </html>
  </apex:page>