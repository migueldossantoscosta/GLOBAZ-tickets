    function construirMapaAutodromo(stands, ocupados){
        const oc = new Set(ocupados);
        ocupadosCount = oc.size;

        // Esconde a estrutura SBA e mostra o SVG da pista
        document.querySelector('.arena').innerHTML = `
        <div style="font-size:11px;color:#999;text-align:center;margin-bottom:8px;">Clica num stand para ver os lugares</div>
        <svg id="track-svg" width="100%" viewBox="0 0 680 360" style="display:block;">
          <path d="M 60,310 L 580,310 Q 630,310 630,265 Q 630,235 600,230 L 530,228 Q 510,228 510,210 Q 510,192 530,190 L 600,188 Q 640,185 640,150 Q 640,110 600,108 L 490,108 Q 460,108 445,128 L 420,158 Q 405,175 385,165 L 355,148 Q 335,138 335,118 Q 335,95 355,85 L 415,60 Q 440,48 440,28 Q 440,10 415,8 L 310,8 Q 285,8 270,25 L 240,58 Q 225,75 200,75 L 155,75 Q 120,75 105,100 Q 88,128 105,155 L 135,190 Q 148,208 135,225 L 105,258 Q 88,278 95,305 Q 98,310 110,312" fill="none" stroke="#d1d5db" stroke-width="22" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M 60,310 L 580,310 Q 630,310 630,265 Q 630,235 600,230 L 530,228 Q 510,228 510,210 Q 510,192 530,190 L 600,188 Q 640,185 640,150 Q 640,110 600,108 L 490,108 Q 460,108 445,128 L 420,158 Q 405,175 385,165 L 355,148 Q 335,138 335,118 Q 335,95 355,85 L 415,60 Q 440,48 440,28 Q 440,10 415,8 L 310,8 Q 285,8 270,25 L 240,58 Q 225,75 200,75 L 155,75 Q 120,75 105,100 Q 88,128 105,155 L 135,190 Q 148,208 135,225 L 105,258 Q 88,278 95,305 Q 98,310 110,312" fill="none" stroke="#e5e7eb" stroke-width="16" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M 60,310 L 580,310 Q 630,310 630,265 Q 630,235 600,230 L 530,228 Q 510,228 510,210 Q 510,192 530,190 L 600,188 Q 640,185 640,150 Q 640,110 600,108 L 490,108 Q 460,108 445,128 L 420,158 Q 405,175 385,165 L 355,148 Q 335,138 335,118 Q 335,95 355,85 L 415,60 Q 440,48 440,28 Q 440,10 415,8 L 310,8 Q 285,8 270,25 L 240,58 Q 225,75 200,75 L 155,75 Q 120,75 105,100 Q 88,128 105,155 L 135,190 Q 148,208 135,225 L 105,258 Q 88,278 95,305 Q 98,310 110,312" fill="none" stroke="#9ca3af" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="200" y1="326" x2="500" y2="326" stroke="#9ca3af" stroke-width="6"/>
          <rect x="388" y="302" width="5" height="30" fill="#111827"/>
          ${gerarStandsSVG(stands, oc)}
        </svg>
        <div id="stand-seats-panel" style="display:none;margin-top:12px;border-top:1px solid #e5e7eb;padding-top:12px;"></div>`;

        // Calcula total de lugares
        let total = 0;
        stands.forEach(s => { total += s.filas.length * s.colunas; });
        document.getElementById('msTotal').innerText = total;
        document.getElementById('msDisp').innerText  = total - ocupadosCount;
        totalSeats = total;
    }

    const STAND_POSITIONS = {
        'samsung':    {x:218, y:18,  w:72,  h:14, vertical:false},
        'portimao':   {x:328, y:36,  w:82,  h:14, vertical:false},
        'standing':   {x:452, y:32,  w:80,  h:14, vertical:false},
        'sagres-top': {x:648, y:100, w:13,  h:68, vertical:true},
        'solverde':   {x:648, y:180, w:13,  h:60, vertical:true},
        'sagres-bot': {x:648, y:252, w:13,  h:60, vertical:true},
        'lagos':      {x:60,  y:118, w:13,  h:58, vertical:true, flip:true},
        'meo':        {x:60,  y:200, w:13,  h:72, vertical:true, flip:true},
        'millennium': {x:170, y:340, w:190, h:14, vertical:false},
    };

    function gerarStandsSVG(stands, oc){
        return stands.map(s => {
            const p = STAND_POSITIONS[s.id];
            if(!p) return '';
            const ocupadosStand = [...oc].filter(k => k.startsWith(s.id+':')).length;
            const total = s.filas.length * s.colunas;
            const cx = p.x + p.w/2;
            const cy = p.y + p.h/2;
            const labelRotate = p.vertical ? (p.flip ? `rotate(-90,${cx-14},${cy})` : `rotate(90,${cx+14},${cy})`) : '';
            const labelX = p.vertical ? (p.flip ? cx-14 : cx+14) : cx;
            const labelY = p.vertical ? cy : cy;
            const shortLabel = s.label.replace('Stand ','').replace(' Area','');
            return `
            <g style="cursor:pointer;" onclick="abrirStand('${s.id}')">
              <rect x="${p.x}" y="${p.y}" width="${p.w}" height="${p.h}" rx="3" fill="${s.cor}" fill-opacity="0.9" stroke-width="0.5"/>
              <text x="${labelX}" y="${labelY}" text-anchor="middle" dominant-baseline="central" transform="${labelRotate}" style="font-size:7px;fill:white;font-weight:700;pointer-events:none;">${shortLabel}</text>
            </g>`;
        }).join('');
    }

    let standAtual = null;

    function abrirStand(standId){
        standAtual = standId;
        const stand = STANDS_AA.find(s => s.id === standId);
        if(!stand) return;

        const panel = document.getElementById('stand-seats-panel');
        panel.style.display = 'block';

        let html = `<div style="font-size:13px;font-weight:700;color:${stand.cor};margin-bottom:10px;">${stand.label}</div>`;

        stand.filas.forEach(fila => {
            html += `<div style="font-size:10px;color:#999;margin:6px 0 3px;">Fila ${fila}</div><div style="display:flex;gap:3px;flex-wrap:wrap;">`;
            for(let n=1; n<=stand.colunas; n++){
                const k = standId + ':' + fila + '-' + n;
                const isOc = ocupadosGlobal.has(fila + '-' + n + '-' + standId);
                const isSel = selecionados.findIndex(s => s.k === k) > -1;
                const bg = isSel ? stand.cor : isOc ? '#e5e7eb' : '#fff';
                const color = isSel ? '#fff' : isOc ? '#bbb' : '#666';
                const cursor = isOc ? 'not-allowed' : 'pointer';
                const opacity = isOc ? '0.3' : '1';
                html += `<div onclick="${isOc ? '' : `toggleStandSeat('${standId}','${fila}',${n},'${stand.cor}')`}"
                    style="width:20px;height:18px;border-radius:3px;border:1px solid #e2e2e7;
                    background:${bg};color:${color};cursor:${cursor};opacity:${opacity};
                    display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:500;">
                    ${n}</div>`;
            }
            html += '</div>';
        });

        panel.innerHTML = html;
        updateStatsAA();
    }

    function makeSvgEl(tag, attrs){
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for(const k in attrs){
        el.setAttribute(k, attrs[k]);
    }
    return el;
}

function makeMeoSeatRect(group, x, y, w, h, fila, lugar, zona, ocupadosSet){
    totalSeats++;
    const k = fila + '-' + lugar;
    const ocupado = ocupadosSet.has(k);

    const seat = makeSvgEl('rect', {
        x: x, y: y, width: w, height: h, rx: 1.5, ry: 1.5,
        class: 'seat ' + zona + (ocupado ? ' ocupado' : '')
    });

    seat.dataset.k = k;
    seat.dataset.fila = fila;
    seat.dataset.lugar = lugar;
    seat.style.cursor = ocupado ? 'not-allowed' : 'pointer';

    if(!ocupado){
        seat.onclick = function(){
            const idx = selecionados.findIndex(s => s.k === k);
            if(idx > -1){
                selecionados.splice(idx,1);
                seat.classList.remove('selecionado');
            } else {
                selecionados.push({k, fila:fila, lugar:lugar});
                seat.classList.add('selecionado');
            }
            document.getElementById('count').innerText  = selecionados.length;
            document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
            document.getElementById('msSel').innerText  = selecionados.length;
            document.getElementById('msDisp').innerText = totalSeats - ocupadosCount - selecionados.length;
        };
    }

    group.appendChild(seat);
}

function makeMeoSeatArc(group, cx, cy, angleDeg, radius, w, h, fila, lugar, zona, ocupadosSet){
    totalSeats++;
    const k = fila + '-' + lugar;
    const ocupado = ocupadosSet.has(k);

    const rad = angleDeg * Math.PI / 180;
    const x = cx + Math.cos(rad) * radius - w / 2;
    const y = cy + Math.sin(rad) * radius - h / 2;

    const seat = makeSvgEl('rect', {
        x: x,
        y: y,
        width: w,
        height: h,
        rx: 1.5,
        ry: 1.5,
        transform: 'rotate(' + (angleDeg + 90) + ' ' + (x + w/2) + ' ' + (y + h/2) + ')',
        class: 'seat ' + zona + (ocupado ? ' ocupado' : '')
    });

    seat.dataset.k = k;
    seat.dataset.fila = fila;
    seat.dataset.lugar = lugar;
    seat.style.cursor = ocupado ? 'not-allowed' : 'pointer';

    if(!ocupado){
        seat.onclick = function(){
            const idx = selecionados.findIndex(s => s.k === k);
            if(idx > -1){
                selecionados.splice(idx,1);
                seat.classList.remove('selecionado');
            } else {
                selecionados.push({k, fila:fila, lugar:lugar});
                seat.classList.add('selecionado');
            }
            document.getElementById('count').innerText  = selecionados.length;
            document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
            document.getElementById('msSel').innerText  = selecionados.length;
            document.getElementById('msDisp').innerText = totalSeats - ocupadosCount - selecionados.length;
        };
    }

    group.appendChild(seat);
}

