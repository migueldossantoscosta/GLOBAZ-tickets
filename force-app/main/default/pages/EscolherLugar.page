        document.getElementById('msTotal').innerText = total;
        document.getElementById('msDisp').innerText  = total - ocupadosCount;
        totalSeats = total;
    }

    const STAND_POSITIONS = {
        'samsung':    {x:218, y:18,  w:72,  h:14, vertical:false},
        'portimao':   {x:328, y:36,  w:82,  h:14, vertical:false},
        'standing':   {x:452, y:32,  w:80,  h:14, vertical:false},
        'sagres-top': {x:648, y:100, w:13,  h:68, vertical:true},
        'solverde':   {x:648, y:180, w:13,  h:60, vertical:true},
        'sagres-bot': {x:648, y:252, w:13,  h:60, vertical:true},
        'lagos':      {x:60,  y:118, w:13,  h:58, vertical:true, flip:true},
        'meo':        {x:60,  y:200, w:13,  h:72, vertical:true, flip:true},
        'millennium': {x:170, y:340, w:190, h:14, vertical:false},
    };

    function gerarStandsSVG(stands, oc){
        return stands.map(s => {
            const p = STAND_POSITIONS[s.id];
            if(!p) return '';
            const ocupadosStand = [...oc].filter(k => k.startsWith(s.id+':')).length;
            const total = s.filas.length * s.colunas;
            const cx = p.x + p.w/2;
            const cy = p.y + p.h/2;
            const labelRotate = p.vertical ? (p.flip ? `rotate(-90,${cx-14},${cy})` : `rotate(90,${cx+14},${cy})`) : '';
            const labelX = p.vertical ? (p.flip ? cx-14 : cx+14) : cx;
            const labelY = p.vertical ? cy : cy;
            const shortLabel = s.label.replace('Stand ','').replace(' Area','');
            return `
            <g style="cursor:pointer;" onclick="abrirStand('${s.id}')">
              <rect x="${p.x}" y="${p.y}" width="${p.w}" height="${p.h}" rx="3" fill="${s.cor}" fill-opacity="0.9" stroke-width="0.5"/>
              <text x="${labelX}" y="${labelY}" text-anchor="middle" dominant-baseline="central" transform="${labelRotate}" style="font-size:7px;fill:white;font-weight:700;pointer-events:none;">${shortLabel}</text>
            </g>`;
        }).join('');
    }

    let standAtual = null;

    function abrirStand(standId){
        standAtual = standId;
        const stand = STANDS_AA.find(s => s.id === standId);
        if(!stand) return;

        const panel = document.getElementById('stand-seats-panel');
        panel.style.display = 'block';

        let html = `<div style="font-size:13px;font-weight:700;color:${stand.cor};margin-bottom:10px;">${stand.label}</div>`;

        stand.filas.forEach(fila => {
            html += `<div style="font-size:10px;color:#999;margin:6px 0 3px;">Fila ${fila}</div><div style="display:flex;gap:3px;flex-wrap:wrap;">`;
            for(let n=1; n<=stand.colunas; n++){
                const k = standId + ':' + fila + '-' + n;
                const isOc = ocupadosGlobal.has(fila + '-' + n + '-' + standId);
                const isSel = selecionados.findIndex(s => s.k === k) > -1;
                const bg = isSel ? stand.cor : isOc ? '#e5e7eb' : '#fff';
                const color = isSel ? '#fff' : isOc ? '#bbb' : '#666';
                const cursor = isOc ? 'not-allowed' : 'pointer';
                const opacity = isOc ? '0.3' : '1';
                html += `<div onclick="${isOc ? '' : `toggleStandSeat('${standId}','${fila}',${n},'${stand.cor}')`}"
                    style="width:20px;height:18px;border-radius:3px;border:1px solid #e2e2e7;
                    background:${bg};color:${color};cursor:${cursor};opacity:${opacity};
                    display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:500;">
                    ${n}</div>`;
            }
            html += '</div>';
        });

        panel.innerHTML = html;
        updateStatsAA();
    }

    function makeSvgEl(tag, attrs){
    const el = document.createElementNS('http://www.w3.org/2000/svg', tag);
    for(const k in attrs){
        el.setAttribute(k, attrs[k]);
    }
    return el;
}

function makeMeoSeatRect(group, x, y, w, h, fila, lugar, zona, ocupadosSet){
    totalSeats++;
    const k = getPrefixedFila(fila, zona) + '-' + lugar + '-' + zona;
    const ocupado = ocupadosSet.has(k);

    const seat = makeSvgEl('rect', {
        x: x, y: y, width: w, height: h, rx: 1.5, ry: 1.5,
        class: 'seat ' + zona + (ocupado ? ' ocupado' : '')
    });

    seat.dataset.k = k;
    seat.dataset.fila = fila;
    seat.dataset.lugar = lugar;
    seat.style.cursor = ocupado ? 'not-allowed' : 'pointer';

    if(!ocupado){
        seat.onclick = function(){
            const idx = selecionados.findIndex(s => s.k === k);
            if(idx > -1){
                selecionados.splice(idx,1);
                seat.classList.remove('selecionado');
            } else {
                const tipo = getTipoBilhete(zona); selecionados.push({k, fila:fila, lugar:lugar, stand: zona, tipo: tipo});
                seat.classList.add('selecionado');
            }
            document.getElementById('count').innerText  = selecionados.length;
            document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
            document.getElementById('msSel').innerText  = selecionados.length;
            document.getElementById('msDisp').innerText = totalSeats - ocupadosCount - selecionados.length;
        };
    }

    group.appendChild(seat);
}

function makeMeoSeatArc(group, cx, cy, angleDeg, radius, w, h, fila, lugar, zona, ocupadosSet){
    totalSeats++;
    const k = getPrefixedFila(fila, zona) + '-' + lugar + '-' + zona;
    const ocupado = ocupadosSet.has(k);

    const rad = angleDeg * Math.PI / 180;
    const x = cx + Math.cos(rad) * radius - w / 2;
    const y = cy + Math.sin(rad) * radius - h / 2;

    const seat = makeSvgEl('rect', {
        x: x,
        y: y,
        width: w,
        height: h,
        rx: 1.5,
        ry: 1.5,
        transform: 'rotate(' + (angleDeg + 90) + ' ' + (x + w/2) + ' ' + (y + h/2) + ')',
        class: 'seat ' + zona + (ocupado ? ' ocupado' : '')
    });

    seat.dataset.k = k;
    seat.dataset.fila = fila;
    seat.dataset.lugar = lugar;
    seat.style.cursor = ocupado ? 'not-allowed' : 'pointer';

    if(!ocupado){
        seat.onclick = function(){
            const idx = selecionados.findIndex(s => s.k === k);
            if(idx > -1){
                selecionados.splice(idx,1);
                seat.classList.remove('selecionado');
            } else {
                const tipo = getTipoBilhete(zona); selecionados.push({k, fila:fila, lugar:lugar, stand: zona, tipo: tipo});
                seat.classList.add('selecionado');
            }
            document.getElementById('count').innerText  = selecionados.length;
            document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
            document.getElementById('msSel').innerText  = selecionados.length;
            document.getElementById('msDisp').innerText = totalSeats - ocupadosCount - selecionados.length;
        };
    }

    group.appendChild(seat);
}

        function construirMapaMeoArena(mapa, ocupados){
            const NS2 = 'http://www.w3.org/2000/svg';
            const COLORS2 = { topo:'#fb923c', ring:'#38bdf8', plateia:'#34d399', lat:'#c084fc' };
            const oc = new Set(ocupados);
            ocupadosCount = oc.size;
            totalSeats = 0;

            const arena = document.querySelector('.arena');
            arena.innerHTML = '';
            arena.style.cssText = 'background:none;border:none;padding:0;';

            // Build the SVG arena
            const svgWrap = document.createElement('div');
            svgWrap.style.cssText = 'width:100%;max-width:860px;margin:0 auto;';

            const svg = document.createElementNS(NS2,'svg');
            svg.setAttribute('width','100%');
            svg.setAttribute('viewBox','0 0 680 780');
            svg.setAttribute('id','meoArenaSvg');
            svg.style.display='block';

            // Arena shell
            const shell1 = document.createElementNS(NS2,'ellipse');
            shell1.setAttribute('cx','340'); shell1.setAttribute('cy','370');
            shell1.setAttribute('rx','303'); shell1.setAttribute('ry','353');
            shell1.setAttribute('fill','#0d1424');
            shell1.setAttribute('stroke','rgba(255,255,255,0.12)');
            shell1.setAttribute('stroke-width','1.5');
            svg.appendChild(shell1);

            const shell2 = document.createElementNS(NS2,'ellipse');
            shell2.setAttribute('cx','340'); shell2.setAttribute('cy','370');
            shell2.setAttribute('rx','295'); shell2.setAttribute('ry','345');
            shell2.setAttribute('fill','#111827');
            svg.appendChild(shell2);

            // Stage
            const stageG = document.createElementNS(NS2,'g');
            const stageRect = document.createElementNS(NS2,'rect');
            stageRect.setAttribute('x','278'); stageRect.setAttribute('y','648');
            stageRect.setAttribute('width','124'); stageRect.setAttribute('height','52');
            stageRect.setAttribute('rx','8');
            stageRect.setAttribute('fill','#1e293b');
            stageRect.setAttribute('stroke','#60a5fa');
            stageRect.setAttribute('stroke-width','1.5');
            stageG.appendChild(stageRect);
            const stageTxt = document.createElementNS(NS2,'text');
            stageTxt.setAttribute('x','340'); stageTxt.setAttribute('y','679');
            stageTxt.setAttribute('text-anchor','middle');
            stageTxt.setAttribute('font-size','12');
            stageTxt.setAttribute('font-weight','600');
            stageTxt.setAttribute('fill','#93c5fd');
            stageTxt.setAttribute('letter-spacing','3');
            stageTxt.textContent = 'PALCO';
            stageG.appendChild(stageTxt);
            svg.appendChild(stageG);

            // Seat groups
            const gTopo    = document.createElementNS(NS2,'g'); gTopo.id    = 'g-topo-meo';
            const gRing    = document.createElementNS(NS2,'g'); gRing.id    = 'g-ring-meo';
            const gPlateia = document.createElementNS(NS2,'g'); gPlateia.id = 'g-plateia-meo';
            const gLatL    = document.createElementNS(NS2,'g'); gLatL.id    = 'g-lat-l-meo';
            const gLatR    = document.createElementNS(NS2,'g'); gLatR.id    = 'g-lat-r-meo';
            svg.appendChild(gTopo);
            svg.appendChild(gRing);
            svg.appendChild(gPlateia);
            svg.appendChild(gLatL);
            svg.appendChild(gLatR);
            svgWrap.appendChild(svg);
            arena.appendChild(svgWrap);

            function addMeoSeat(parent, cx, cy, w, h, zone, key, angleDeg){
                totalSeats++;
                const isOc = oc.has(key);
                if(isOc) ocupadosCount = oc.size; // already counted

                const r2 = document.createElementNS(NS2,'rect');
                r2.setAttribute('x', cx - w/2);
                r2.setAttribute('y', cy - h/2);
                r2.setAttribute('width', w);
                r2.setAttribute('height', h);
                r2.setAttribute('rx', 1.5);

                if(isOc){
                    r2.setAttribute('fill','#ff3b7f');
                    r2.setAttribute('opacity','0.35');
                    r2.style.cursor='not-allowed';
                } else {
                    r2.setAttribute('fill', COLORS2[zone]);
                    r2.setAttribute('stroke','rgba(0,0,0,0.3)');
                    r2.setAttribute('stroke-width','0.4');
                    r2.style.cursor='pointer';
                    r2.style.transition='opacity 0.15s';
                    r2.onmouseenter = function(){ r2.setAttribute('opacity','0.75'); };
                    r2.onmouseleave = function(){ if(!selecionados.find(s=>s.k===key)) r2.setAttribute('opacity','1'); };
                    r2.onclick = function(){
                        const idx = selecionados.findIndex(s => s.k === key);
                        const tipo = getTipoBilhete(zone);
                        if(idx > -1){
                            selecionados.splice(idx,1);
                            r2.setAttribute('fill', COLORS2[zone]);
                            r2.setAttribute('stroke','rgba(0,0,0,0.3)');
                            r2.setAttribute('stroke-width','0.4');
                            r2.setAttribute('opacity','1');
                        } else {
                            selecionados.push({k:key, fila:zone+'-seat', lugar:key, stand:zone, tipo:tipo});
                            r2.setAttribute('fill','#fbbf24');
                            r2.setAttribute('stroke','#fff');
                            r2.setAttribute('stroke-width','1.5');
                            r2.setAttribute('opacity','1');
                        }
                        document.getElementById('count').innerText  = selecionados.length;
                        document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
                        document.getElementById('msSel').innerText  = selecionados.length;
                        document.getElementById('msDisp').innerText = totalSeats - oc.size - selecionados.length;
                    };
                }

                if(angleDeg && angleDeg !== 0){
                    r2.setAttribute('transform','rotate('+angleDeg+' '+cx+' '+cy+')');
                }
                r2.dataset.k = key;
                parent.appendChild(r2);
            }

            // ── TOPO ───────────────────────────────────────
            (function(){
                const SW=8, SH=6, GX=2, GY=4;
                const filas = [
                    {fila:'A', cols:20, y:80},
                    {fila:'B', cols:24, y:80+SH+GY},
                    {fila:'C', cols:28, y:80+2*(SH+GY)},
                    {fila:'D', cols:30, y:80+3*(SH+GY)},
                    {fila:'E', cols:32, y:80+4*(SH+GY)},
                ];
                filas.forEach(function(f){
                    const totalW = f.cols*(SW+GX) - GX;
                    const startX = 340 - totalW/2;
                    for(let c=0; c<f.cols; c++){
                        addMeoSeat(gTopo, startX+c*(SW+GX)+SW/2, f.y+SH/2, SW, SH, 'topo', 'meo-topo-'+f.fila+'-'+(c+1), 0);
                    }
                });
            })();

            // ── ANEL / RING ────────────────────────────────
            (function(){
                const CX=340, CY=370;
                const SW=7, SH=13;
                const rings2 = [
                    {R:160, fila:'R1'},
                    {R:175, fila:'R2'},
                    {R:190, fila:'R3'},
                ];
                rings2.forEach(function(ring){
                    const startDeg=150, endDeg=390;
                    const nSeats = Math.round((endDeg-startDeg)/360 * 2*Math.PI*ring.R / 14);
                    const step = (endDeg-startDeg)/nSeats;
                    let idx=0;
                    for(let i=0; i<=nSeats; i++){
                        const deg = startDeg + i*step;
                        const norm = ((deg%360)+360)%360;
                        if(norm>50  && norm<130) continue;
                        if(norm>255 && norm<285) continue;
                        const rad = deg*Math.PI/180;
                        const x = CX + Math.cos(rad)*ring.R;
                        const y = CY + Math.sin(rad)*ring.R;
                        addMeoSeat(gRing, x, y, SW, SH, 'ring', 'meo-ring-'+ring.fila+'-'+(++idx), deg+90);
                    }
                });
            })();

            // ── PLATEIA CENTRAL ────────────────────────────
            (function(){
                const SW=9, SH=8, GX=2, GY=3;
                const filas = ['A','B','C','D','E','F','G','H','I','J','K','L','M','N'];
                const colsPerRow = [14,16,18,20,22,22,22,22,22,22,20,18,16,14];
                filas.forEach(function(fila, ri){
                    const cols = colsPerRow[ri];
                    const totalW = cols*(SW+GX) - GX;
                    const startX = 340 - totalW/2;
                    const y = 318 + ri*(SH+GY) + SH/2;
                    for(let c=0; c<cols; c++){
                        addMeoSeat(gPlateia, startX+c*(SW+GX)+SW/2, y, SW, SH, 'plateia', 'meo-plateia-'+fila+'-'+(c+1), 0);
                    }
                });
            })();

            // ── LATERAL ESQUERDA ───────────────────────────
            (function(){
                const SW=8, SH=8, GX=4, GY=2;
                const filas = ['A','B','C','D','E','F','G','H'];
                const seatsPerFila = [10,12,14,15,16,16,15,13];
                filas.forEach(function(fila, fi){
                    const n = seatsPerFila[fi];
                    const cx = 52 + fi*(SW+GX) + SW/2;
                    const totalH = n*(SH+GY) - GY;
                    const startY = 370 - totalH/2;
                    for(let s=0; s<n; s++){
                        addMeoSeat(gLatL, cx, startY+s*(SH+GY)+SH/2, SW, SH, 'lat', 'meo-lat-l-'+fila+'-'+(s+1), 0);
                    }
                });
            })();

            // ── LATERAL DIREITA ────────────────────────────
            (function(){
                const SW=8, SH=8, GX=4, GY=2;
                const filas = ['A','B','C','D','E','F','G','H'];
                const seatsPerFila = [10,12,14,15,16,16,15,13];
                filas.forEach(function(fila, fi){
                    const n = seatsPerFila[fi];
                    const cx = 628 - fi*(SW+GX) - SW/2;
                    const totalH = n*(SH+GY) - GY;
                    const startY = 370 - totalH/2;
                    for(let s=0; s<n; s++){
                        addMeoSeat(gLatR, cx, startY+s*(SH+GY)+SH/2, SW, SH, 'lat', 'meo-lat-r-'+fila+'-'+(s+1), 0);
                    }
                });
            })();

            // Update legend
            const legEl = document.querySelector('.map-legend');
            if(legEl){
                legEl.innerHTML = `
                    <div class="leg"><div class="ldot" style="background:#38bdf8"></div>Anel</div>
                    <div class="leg"><div class="ldot" style="background:#34d399"></div>Plateia Central</div>
                    <div class="leg"><div class="ldot" style="background:#c084fc"></div>Laterais</div>
                    <div class="leg"><div class="ldot" style="background:#fb923c"></div>Topo</div>
                    <div class="leg"><div class="ldot" style="background:#fbbf24;outline:1.5px solid #e5a000;outline-offset:1px;"></div>Selecionado</div>
                    <div class="leg"><div class="ldot" style="background:#ff3b7f;opacity:.35"></div>Ocupado</div>
                `;
            }

            document.getElementById('msTotal').innerText = totalSeats;
            document.getElementById('msDisp').innerText  = totalSeats - oc.size;
        }

    let ocupadosGlobal = new Set();

    function toggleStandSeat(standId, fila, num, cor){
        const k = getPrefixedFila(fila, standId) + '-' + num + '-' + standId;
        const idx = selecionados.findIndex(s => s.k === k);
        const prefixedFila = getPrefixedFila(fila, standId);
        if(idx > -1){
            selecionados.splice(idx,1);
        } else {
            const tipo = getTipoBilhete(standId);
            selecionados.push({k, fila:prefixedFila, lugar:num, stand:standId, tipo: tipo});
        }
        document.getElementById('count').innerText  = selecionados.length;
        document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
        updateStatsAA();
        if(standAtual) abrirStand(standAtual);
    }

    function updateStatsAA(){
        const total = parseInt(document.getElementById('msTotal').innerText) || 0;
        document.getElementById('msSel').innerText  = selecionados.length;
        document.getElementById('msDisp').innerText = total - ocupadosCount - selecionados.length;
    }

