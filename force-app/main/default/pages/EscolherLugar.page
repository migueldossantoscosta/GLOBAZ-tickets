    }

    function changeExtraQty(pbeId, delta) {
        const current = EXTRAS_SELECCIONADOS[pbeId] || 0;
        const newVal = Math.max(0, current + delta);
        if (newVal === 0) delete EXTRAS_SELECCIONADOS[pbeId];
        else EXTRAS_SELECCIONADOS[pbeId] = newVal;
        
        const el = document.getElementById('qty-' + pbeId);
        if (el) el.innerText = newVal;
        atualizarTotalModal();
    }

    function calcularTotalComExtras() {
        let baseTotal = 0;
        selecionados.forEach(s => {
            const p = PRECO_MAP[s.tipo] || PRECO_MAP['BLT-Geral'] || 25.00;
            baseTotal += p;
        });

        let extrasTotal = 0;
        SERVICOS_EXTRA.forEach(s => {
            if (EXTRAS_SELECCIONADOS[s.id]) extrasTotal += EXTRAS_SELECCIONADOS[s.id] * s.price;
        });
        return baseTotal + extrasTotal;
    }

    function atualizarTotalModal() {
        const finalTotal = calcularTotalComExtras();
        document.getElementById('mTotal').innerText = finalTotal.toLocaleString('pt-PT', { style: 'currency', currency: 'EUR' });
    }

    // ── STEPS E MODAL ─────────────────────────────────────────

    function switchStep(from, to){
        document.getElementById(from).classList.remove('active');
        document.getElementById(to).classList.add('active');
    }

    function irParaStep2(){
        if(selecionados.length === 0){ alert('Selecione pelo menos um lugar!'); return; }
        switchStep('step1','step2');
    }

    function abrirModal(){
        EXTRAS_SELECCIONADOS = {}; // Reset extras ao abrir modal
        renderExtras();
        
        document.getElementById('modalChips').innerHTML = selecionados.map(s => {
            const label = s.stand
                ? `${s.stand.replace('-',' ')} · Fila ${s.fila} · Lugar ${s.lugar}`
                : `Fila ${s.fila} · Lugar ${s.lugar}`;
            return `<div class="chip"><div class="chip-dot"></div>${label}</div>`;
        }).join('');
        
        document.getElementById('mQtd').innerText = selecionados.length;
        
        const totalBase = selecionados.reduce((acc, s) => acc + (PRECO_MAP[s.tipo] || PRECO_MAP['BLT-Geral'] || 25.0), 0);
        const hasVarious = new Set(selecionados.map(s => s.tipo)).size > 1;

        document.getElementById('mPrecoUnit').innerText = hasVarious ? 'Vários' : (totalBase/selecionados.length).toLocaleString('pt-PT', { style: 'currency', currency: 'EUR' });
        document.getElementById('mMetodo').innerText    = metodoAtual;
        
        atualizarTotalModal(); 

        document.getElementById('btnModalPagar').style.background = TEMAS[metodoAtual].btnColor;
        document.getElementById('modalDetalhes').classList.add('open');
    }

    function fecharModal(){
        document.getElementById('modalDetalhes').classList.remove('open');
    }

    function confirmarECriar(){
    const btn = document.getElementById('btnModalPagar');
    btn.innerText = 'A processar...';
    btn.disabled = true;

    let nome  = '';
    let email = '';

    if (!utilizadorLogado) {
        const nomeEl  = document.getElementById('checkoutNome');
        const emailEl = document.getElementById('checkoutEmail');
        nome  = nomeEl  ? nomeEl.value.trim()  : '';
        email = emailEl ? emailEl.value.trim() : '';

        if (!nome) {
            alert('Introduza o nome.');
            btn.innerText = 'Pagar Agora';
            btn.disabled = false;
            return;
        }
        if (!email) {
            alert('Introduza o email.');
            btn.innerText = 'Pagar Agora';
            btn.disabled = false;
            return;
        }
    }

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.BilheteiraController.criarReserva}',
        evtId,
        accId || null,
        metodoAtual,
        nome,
        email,
        function(result, event){
            btn.innerText = 'Pagar Agora';
            btn.disabled = false;

            console.log('criarReserva result:', result);
            console.log('criarReserva event:', event);

            if(!event.status){
                alert('Erro de comunicação: ' + (event.message || 'sem detalhe'));
                return;
            }

            if(result === 'CLIENTE_INVALIDO'){
                fecharModal();
                alert('Cliente inválido.');
                return;
            }

            if(result === 'PAGAMENTO_RECUSADO'){
                fecharModal();
                alert('Pagamento recusado. Contacte o suporte para mais informações.');
                return;
            }

            if(result && result.indexOf('ERRO:') === 0){
                alert(result);
                return;
            }

            orderIdAtiva = result;
            fecharModal();
            aplicarTema(metodoAtual);

            const totalNum = calcularTotalComExtras();
            const totalFmt = totalNum.toLocaleString('pt-PT', { style: 'currency', currency: 'EUR' });
            
            document.getElementById('receipt-lugares').innerText = selecionados.map(s =>
                s.stand ? `${s.stand} ${s.fila}${s.lugar}` : `${s.fila}${s.lugar}`
            ).join(', ');
            document.getElementById('receipt-metodo').innerText  = metodoAtual;
            document.getElementById('total-display').innerText   = totalFmt;
            document.getElementById('trans-id').innerText        = result;

            if(metodoAtual === 'Multibanco'){
                const ref = Math.floor(Math.random()*900000000+100000000).toString();
                document.getElementById('mbRefNum').innerText = ref.slice(0,3)+' '+ref.slice(3,6)+' '+ref.slice(6);
                document.getElementById('mbRefVal').innerText = totalFmt;
                document.getElementById('mbRefBox').style.display = 'block';
            } else {
                document.getElementById('mbRefBox').style.display = 'none';
            }

            switchStep('step2','step3');
                    },
                    { escape: false }
                );
            }

    function finalizarTudo(){
        const btn = document.getElementById('btnFinal');
        btn.innerText = 'A PROCESSAR…'; btn.disabled = true;

        const payload = JSON.stringify(selecionados.map(s => ({
            fila:  s.fila,
            lugar: s.lugar,
            stand: s.stand || null,
            tipo:  s.tipo || 'BLT-Geral'
        })));

        const listExtras = [];
        for (let pId in EXTRAS_SELECCIONADOS) {
            listExtras.push({ pbeId: pId, qty: EXTRAS_SELECCIONADOS[pId] });
        }
        const jsonExtras = JSON.stringify(listExtras);

        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.BilheteiraController.processarPagamentoMock}',
            orderIdAtiva, evtId, payload, jsonExtras,
            function(res, event){
                btn.innerText = TEMAS[metodoAtual].btn; btn.disabled = false;
                if(!event.status){ alert('Erro de comunicação.'); return; }
                if(res === 'PAGAMENTO_RECUSADO'){
                    alert('Pagamento recusado. Contacte o suporte para mais informações.');
                    return;
                }
                if(res !== 'PAGAMENTO_OK'){ alert('Erro: ' + res); return; }

                // Success
                switchStep('step3','step-success');
                confetti({
                    particleCount: 150,
                    spread: 70,
                    origin: { y: 0.6 },
                    colors: ['#2563eb', '#1d4ed8', '#fbbf24', '#ffffff']
                });
            },
            {escape:false}
        );
    }
//]]>
    </script>
</apex:page>