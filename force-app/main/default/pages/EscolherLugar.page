            const ringsG    = document.getElementById('meoRings');

            if(mapa.topo){
                mapa.topo.filas.forEach((filaBase, r) => {
                    const fila = filaBase;
                    for(let c=1; c<=mapa.topo.colunas; c++){
                        makeMeoSeatRect(
                            topoG,
                            mapa.topo.x + ((c-1) * mapa.topo.gap_x),
                            mapa.topo.y + (r * mapa.topo.gap_y),
                            mapa.topo.seat_w,
                            mapa.topo.seat_h,
                            fila,
                            c,
                            mapa.topo.zona,
                            oc
                        );
                    }
                });
            }

            if(mapa.plateia_central){
                mapa.plateia_central.filas.forEach((filaBase, r) => {
                    const fila = filaBase;
                    for(let c=1; c<=mapa.plateia_central.colunas; c++){
                        makeMeoSeatRect(
                            plateiaG,
                            mapa.plateia_central.x + ((c-1) * mapa.plateia_central.gap_x),
                            mapa.plateia_central.y + (r * mapa.plateia_central.gap_y),
                            mapa.plateia_central.seat_w,
                            mapa.plateia_central.seat_h,
                            fila,
                            c,
                            mapa.plateia_central.zona,
                            oc
                        );
                    }
                });
            }

            if(mapa.laterais){
                mapa.laterais.forEach((lat) => {
                    lat.blocos.forEach((bloco, bi) => {
                        bloco.filas.forEach((filaBase, r) => {
                            const fila = filaBase;
                            for(let c=1; c<=bloco.colunas; c++){
                                makeMeoSeatRect(
                                    lateraisG,
                                    lat.x + ((c-1) * lat.gap_x),
                                    bloco.y + (r * lat.gap_y),
                                    lat.seat_w,
                                    lat.seat_h,
                                    fila,
                                    c,
                                    lat.zona,
                                    oc
                                );
                            }
                        });
                    });
                });
            }

            if(mapa.ring_seats && mapa.rings){
                mapa.rings.forEach((ring) => {
                    for(let i=0; i<ring.quantidade; i++){
                        const t = i / (ring.quantidade - 1);
                        const ang = ring.angulo_inicio + ((ring.angulo_fim - ring.angulo_inicio) * t);

                        if ((ang > 248 && ang < 292)) continue;
                        if ((ang > 171 && ang < 189)) continue;
                        if ((ang > 351 && ang < 369)) continue;

                        makeMeoSeatArc(
                            ringsG,
                            450,
                            690,
                            ang,
                            ring.raio,
                            10,
                            24,
                            ring.prefixo_fila,
                            i + 1,
                            ring.zona,
                            oc
                        );
                    }
                });
            }

            document.getElementById('msTotal').innerText = totalSeats;
            document.getElementById('msDisp').innerText  = totalSeats - ocupadosCount;
        }

    let ocupadosGlobal = new Set();

