    <script type="text/javascript">
    //<![CDATA[
    function decodeHtml(str){
        const txt = document.createElement('textarea');
        txt.innerHTML = str;
        return txt.value;
    }
    let ROWS_FRENTE  = [];
    let ROWS_TRAS    = [];
    let FRONT_BLOCKS = [];
    let COLS_TRAS    = 0;
    let ZONA_TRAS    = '';
    let PRECO        = 25.00;
    let PRECO_MAP    = {'BLT-Geral': 25.00};
    let TIPO_MAPA    = 'sba';
    let STANDS_AA    = [];
    let STANDS_TEATRO = [];
    let SERVICOS_EXTRA = [];
    let EXTRAS_SELECCIONADOS = {}; // {pbeId: qty}

    let ocupadosCount = 0;
    let selecionados  = [];
    let metodoAtual   = 'MBWay';
    let orderIdAtiva  = '';
    let totalSeats    = 0;

    const evtId = '{!idDoEvento}';
    const accId = '{!idDaAccount}';
    
    const ZONE_PREFIXES = {
        'samsung': 'SA-', 'portimao': 'PA-', 'standing': 'ST-', 'sagres-top': 'STP-',
        'solverde': 'SOL-', 'sagres-bot': 'SBT-', 'lagos': 'LAG-', 'meo': 'ME-',
        'millennium': 'MIL-', 'topo': 'TP-', 'laterais': 'LT-', 'plateia_central': 'PC-',
        'plateia_verde': 'PV-', 'plateia_azul': 'PAZ-', 'camarote': 'CAM-', 'fila_frontal': 'FF-'
    };
    function getPrefixedFila(fila, zoneId){
        const prefix = (zoneId && ZONE_PREFIXES[zoneId.toLowerCase()]) || '';
        return prefix + fila;
    }

    function getTipoBilhete(zona) {
        if (!zona) return 'BLT-Geral';
        const z = zona.toLowerCase();
        // Mapeamento: Sagres = CAMAROTE (Portimão)
        if (z.includes('sagres')) return 'BLT-CAMAROTE';
        // MEO Arena: Laterais (roxo) = VIP, Topo (laranja) = Camarote
        if (z === 'lat')  return 'BLT-VIP';
        if (z === 'topo') return 'BLT-CAMAROTE';
        // Mapeamento genérico: Central/Verde/Green = VIP, Camarote/Box = Camarote, resto = Geral
        if (z.includes('central') || z.includes('verde') || z.includes('front') || z.includes('green')) return 'BLT-VIP';
        if (z.includes('camarote') || z.includes('box') || z.includes('sagres')) return 'BLT-CAMAROTE';
        return 'BLT-Geral';
    }

    // Detectar se utilizador está logado pelo accId
    const utilizadorLogado = (accId && accId !== 'null' && accId.length > 0);

    // Quando a página carrega, mostrar bloco correto e preencher nome se disponível
    document.addEventListener('DOMContentLoaded', function() {
        if (utilizadorLogado) {
            var blocoAnonimo = document.getElementById('blocoAnonimo');
            var blocoConta   = document.getElementById('blocoConta');
            var nomeConta    = document.getElementById('nomeContaLogada');
            if (blocoAnonimo) blocoAnonimo.style.display = 'none';
            if (blocoConta)   blocoConta.style.display   = 'block';
            if (nomeConta)    nomeConta.innerText         = 'A carregar…';

            // Buscar o nome real da conta via RemoteAction
            BilheteiraController.getNomeAccount(accId, function(result, event) {
                if (event.status && result) {
                    if (nomeConta) nomeConta.innerText = result;
                } else {
                    if (nomeConta) nomeConta.innerText = 'Utilizador registado';
                }
            }, { escape: false });
        }
    });

    const TEMAS = {
        'MBWay':      {cls:'t-mbway', logo:'MB <span>WAY</span>',     sub:'COMPROVATIVO DIGITAL',    btn:'VALIDAR PAGAMENTO', btnColor:'#e30613'},
        'Multibanco': {cls:'t-mb',    logo:'MULTI<span>BANCO</span>', sub:'REFERÊNCIA DE PAGAMENTO', btn:'GERAR REFERÊNCIA',  btnColor:'#005ea6'},
        'Cartão':     {cls:'t-card',  logo:'globa<span>z</span>',      sub:'PAGAMENTO POR CARTÃO',    btn:'VALIDAR PAGAMENTO', btnColor:'#16a34a'},
    };

    function aplicarTema(m){
        document.body.classList.remove('t-mbway','t-mb','t-card');
        const t = TEMAS[m]; if(!t) return;
        document.body.classList.add(t.cls);
        document.getElementById('logo-text').innerHTML     = t.logo;
        document.getElementById('subtitle-text').innerText = t.sub;
        document.getElementById('btnFinal').innerText      = t.btn;
    }

    function selectMetodo(m, el){
        metodoAtual = m;
        document.querySelectorAll('.method-opt').forEach(o => o.classList.remove('active'));
        el.classList.add('active');
        aplicarTema(m);
    }

    function makeForumSeat(group, x, y, w, h, fila, lugar, zona, ocupado){
    totalSeats++;

    const k = getPrefixedFila(fila, zona) + '-' + lugar + '-' + zona;

    const seat = makeSvgEl('rect', {
        x: x,
        y: y,
        width: w,
        height: h,
        rx: 2,
        ry: 2
    });

    let fill = '#cccccc';
    if(zona === 'plateia_verde') fill = '#72c53d';
    if(zona === 'plateia_azul') fill = '#0ea5a8';
    if(zona === 'camarote') fill = '#b06ac9';
    if(zona === 'fila_frontal') fill = '#c7d72d';

    seat.setAttribute('fill', fill);
    seat.setAttribute('stroke', 'rgba(0,0,0,.18)');
    seat.setAttribute('stroke-width', '0.6');
    seat.dataset.k = k;

    if (ocupado) {
        seat.setAttribute('opacity', '0.28');
        seat.style.cursor = 'not-allowed';
    } else {
        seat.style.cursor = 'pointer';
        seat.onclick = function(){
            const idx = selecionados.findIndex(s => s.k === k);
            if(idx > -1){
                selecionados.splice(idx, 1);
                seat.setAttribute('stroke', 'rgba(0,0,0,.18)');
                seat.setAttribute('stroke-width', '0.6');
            } else {
                const prefixedFila = getPrefixedFila(fila, zona);
                const tipo = getTipoBilhete(zona);
                selecionados.push({
                    k: k,
                    fila: prefixedFila,
                    lugar: lugar,
                    stand: zona,
                    tipo: tipo
                });
                seat.setAttribute('stroke', '#fbbf24');
                seat.setAttribute('stroke-width', '2');
            }

            document.getElementById('count').innerText  = selecionados.length;
            document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
            document.getElementById('msSel').innerText  = selecionados.length;
            document.getElementById('msDisp').innerText = totalSeats - ocupadosCount - selecionados.length;
        };
    }

    group.appendChild(seat);
    }

    function buildForumQuadBlock(g, bloco, ocupadosSet, seatW, seatH){
        const path = makeSvgEl('polygon', {
            points: [
                bloco.x + ',' + bloco.y,
                (bloco.x + bloco.w) + ',' + (bloco.y + 12),
                (bloco.x + bloco.w - bloco.skew) + ',' + (bloco.y + bloco.h),
                (bloco.x - bloco.skew) + ',' + (bloco.y + bloco.h - 10)
            ].join(' '),
            fill: bloco.zona === 'plateia_verde' ? '#72c53d' : '#0ea5a8',
            stroke: 'none'
        });
        g.appendChild(path);

        const innerPaddingX = 18;
        const innerPaddingY = 18;
        const cols = bloco.colunas;
        const rows = bloco.filas.length;
        const gapX = Math.max(3, (bloco.w - (innerPaddingX * 2) - (cols * seatW)) / Math.max(1, cols - 1));
        const gapY = Math.max(4, (bloco.h - (innerPaddingY * 2) - (rows * seatH)) / Math.max(1, rows - 1));

        for(let r = 0; r < rows; r++){
            const fila = bloco.filas[r];
            for(let c = 0; c < cols; c++){
                const lugar = c + 1;
                const ocupado = ocupadosSet.has(fila + '-' + lugar);

                makeForumSeat(
                    g,
                    bloco.x + innerPaddingX + (c * (seatW + gapX)),
                    bloco.y + innerPaddingY + (r * (seatH + gapY)),
                    seatW,
                    seatH,
                    fila,
                    lugar,
                    bloco.zona,
                    ocupado
                );
            }
        }
    }

    function buildForumRowBlock(g, bloco, ocupadosSet, seatW, seatH){
        const fila = bloco.fila || 'AK';

        for(let i = 0; i < bloco.lugares.length; i++){
            const lugar = bloco.lugares[i];
            const ocupado = ocupadosSet.has(fila + '-' + lugar);

            makeForumSeat(
                g,
                bloco.x + (i * (seatW + 6)),
                bloco.y,
                seatW,
                seatH,
                fila,
                lugar,
                bloco.zona,
                ocupado
            );

            const txt = makeSvgEl('text', {
                x: bloco.x + (i * (seatW + 6)) + (seatW / 2),
                y: bloco.y + seatH + 12,
                'text-anchor': 'middle',
                'font-size': '9',
                fill: '#111'
            });
            txt.textContent = lugar;
            g.appendChild(txt);
        }
    }

    function buildForumBoxBlock(g, bloco, ocupadosSet, seatW, seatH){
        const box = makeSvgEl('rect', {
            x: bloco.x,
            y: bloco.y,
            width: 36,
            height: 68,
            rx: 2,
            fill: '#b06ac9'
        });
        g.appendChild(box);

        for(let r = 0; r < bloco.rows; r++){
            const fila = bloco.filas[r];
            for(let c = 0; c < bloco.cols; c++){
                const lugar = c + 1;
                const ocupado = ocupadosSet.has(fila + '-' + lugar);

                makeForumSeat(
                    g,
                    bloco.x + 6 + (c * (seatW + 4)),
                    bloco.y + 6 + (r * (seatH + 3)),
                    seatW,
                    seatH,
                    fila,
                    lugar,
                    bloco.zona,
                    ocupado
                );
            }
        }
    }

    function construirMapaForumBraga(mapa, ocupados){
        const oc = new Set(ocupados);
        ocupadosCount = oc.size;
        totalSeats = 0;

        const arena = document.querySelector('.arena');
        arena.innerHTML = `
            <div style="display:flex;justify-content:center;margin-bottom:10px;">
                <div style="background:#bfc3c7;color:#fff;font-weight:800;font-size:24px;padding:10px 34px;border-radius:2px;">
                    ${mapa.palco || 'PALCO'}
                </div>
            </div>
            <svg id="forum-braga-svg" viewBox="0 0 620 820" style="width:100%;height:auto;display:block;background:#efefef;border-radius:20px;"></svg>
        `;

        const svg = document.getElementById('forum-braga-svg');
        const g = makeSvgEl('g', {});

        mapa.blocos.forEach(bloco => {
            if (bloco.shape === 'quad') {
                buildForumQuadBlock(g, bloco, oc, mapa.seat_w, mapa.seat_h);
            } else if (bloco.shape === 'row') {
                buildForumRowBlock(g, bloco, oc, mapa.seat_w, mapa.seat_h);
            } else if (bloco.shape === 'box') {
                buildForumBoxBlock(g, bloco, oc, 9, 8);
            }
        });

        svg.appendChild(g);

        document.getElementById('msTotal').innerText = totalSeats;
        document.getElementById('msDisp').innerText  = totalSeats - ocupadosCount;

        const legEl = document.querySelector('.map-legend');
        if (legEl) {
            legEl.innerHTML = `
                <div class="leg"><div class="ldot" style="background:#72c53d"></div>Plateia Verde</div>
                <div class="leg"><div class="ldot" style="background:#0ea5a8"></div>Plateia Azul</div>
                <div class="leg"><div class="ldot" style="background:#b06ac9"></div>Camarotes</div>
                <div class="leg"><div class="ldot" style="background:#c7d72d"></div>Fila Frontal</div>
                <div class="leg"><div class="ldot" style="background:#fbbf24;outline:1.5px solid #e5a000;outline-offset:1px;"></div>Selecionado</div>
                <div class="leg"><div class="ldot" style="background:#ff3b7f;opacity:.35"></div>Ocupado</div>
            `;
        }
    }

    // ── MAPA SBA ──────────────────────────────────────────────

    function makeSeatEl(row, num, zone, ocupado){
        totalSeats++;
        const wrap = document.createElement('div');
        wrap.style.cssText = 'display:flex;flex-direction:column;align-items:center;gap:1px;';
        const sn = document.createElement('div');
        sn.style.cssText = 'font-size:6px;color:#bbb;line-height:1;text-align:center;height:7px;font-family:Inter,sans-serif;';
        sn.textContent = num;
        const d = document.createElement('div');
        d.className = 'seat ' + zone + (ocupado ? ' ocupado' : '');
        const k = getPrefixedFila(row, zone) + '-' + num + '-' + zone;
        d.dataset.k = k;
        d.title = 'Fila ' + row + ' · Lugar ' + num;
        if(!ocupado){
            d.onclick = () => {
                const idx = selecionados.findIndex(s => s.k === k);
                const prefixedFila = getPrefixedFila(row, zone);
                if(idx > -1){
                    selecionados.splice(idx,1);
                    d.classList.remove('selecionado');
                } else {
                    const tipo = getTipoBilhete(zone);
                    selecionados.push({k, fila:prefixedFila, lugar:num, stand:zone, tipo: tipo});
                    d.classList.add('selecionado');
                }
                document.getElementById('count').innerText  = selecionados.length;
                document.getElementById('plural').innerText = selecionados.length !== 1 ? 's' : '';
                document.getElementById('msSel').innerText  = selecionados.length;
                document.getElementById('msDisp').innerText = totalSeats - ocupadosCount - selecionados.length;
            };
        }
        wrap.appendChild(sn);
        wrap.appendChild(d);
        return wrap;
    }

    function buildFrontRow(parent, row, ocupadosSet){
        const line = document.createElement('div');
        line.className = 'row-line';
        const lbl = document.createElement('div');
        lbl.style.cssText = 'width:16px;font-size:8px;font-weight:600;color:#bbb;text-align:right;padding-right:5px;flex-shrink:0;padding-bottom:2px;';
        lbl.textContent = row;
        line.appendChild(lbl);
        const bg = document.createElement('div');
        bg.style.cssText = 'display:flex;align-items:flex-end;';
        FRONT_BLOCKS.forEach(item => {
            if(item === 'sm'){ const a=document.createElement('div'); a.style.width='12px'; a.style.flexShrink='0'; bg.appendChild(a); }
            else if(item === 'lg'){ const a=document.createElement('div'); a.style.width='28px'; a.style.flexShrink='0'; bg.appendChild(a); }
            else {
                const blk = document.createElement('div');
                blk.style.cssText = 'display:flex;gap:3px;';
                for(let i=0; i<item.cols; i++){
                    const num = item.start + i;
                    const oc  = ocupadosSet.has(row + '-' + num);
                    blk.appendChild(makeSeatEl(row, num, item.z, oc));
                }
                bg.appendChild(blk);
            }
        });
        line.appendChild(bg);
        parent.appendChild(line);
    }

    function buildBackRow(parent, row, ocupadosSet){
        const line = document.createElement('div');
        line.className = 'row-line';
        const lbl = document.createElement('div');
        lbl.style.cssText = 'width:16px;font-size:8px;font-weight:600;color:#bbb;text-align:right;padding-right:5px;flex-shrink:0;padding-bottom:2px;';
        lbl.textContent = row;
        line.appendChild(lbl);
        const blk = document.createElement('div');
        blk.style.cssText = 'display:flex;gap:3px;';
        // FIX 3 — usa COLS_TRAS e ZONA_TRAS do JSON em vez de hardcoded
        for(let n=1; n<=COLS_TRAS; n++){
            const oc = ocupadosSet.has(row + '-' + n);
            blk.appendChild(makeSeatEl(row, n, ZONA_TRAS, oc));
        }
        line.appendChild(blk);
        parent.appendChild(line);
    }

    function construirMapa(ocupados){
        const oc = new Set(ocupados);
        ocupadosCount = oc.size;
        const frente = document.getElementById('mapa-frente');
        const tras   = document.getElementById('mapa-tras');
        ROWS_FRENTE.forEach(r => buildFrontRow(frente, r, oc));
        ROWS_TRAS.forEach((r, ri) => {
            if(ri > 0 && ri % 5 === 0){
                const sp = document.createElement('div'); sp.style.height='10px'; tras.appendChild(sp);
            }
            buildBackRow(tras, r, oc);
        });
        document.getElementById('msTotal').innerText = totalSeats;
        document.getElementById('msDisp').innerText  = totalSeats - ocupadosCount;
    }

    // ── MAPA AUTÓDROMO ────────────────────────────────────────

    function construirMapaAutodromo(stands, ocupados){
        const oc = new Set(ocupados);
        ocupadosCount = oc.size;

        // Esconde a estrutura SBA e mostra o SVG da pista
        document.querySelector('.arena').innerHTML = `
        <div style="font-size:11px;color:#999;text-align:center;margin-bottom:8px;">Clica num stand para ver os lugares</div>
        <svg id="track-svg" width="100%" viewBox="0 0 680 360" style="display:block;">
          <path d="M 60,310 L 580,310 Q 630,310 630,265 Q 630,235 600,230 L 530,228 Q 510,228 510,210 Q 510,192 530,190 L 600,188 Q 640,185 640,150 Q 640,110 600,108 L 490,108 Q 460,108 445,128 L 420,158 Q 405,175 385,165 L 355,148 Q 335,138 335,118 Q 335,95 355,85 L 415,60 Q 440,48 440,28 Q 440,10 415,8 L 310,8 Q 285,8 270,25 L 240,58 Q 225,75 200,75 L 155,75 Q 120,75 105,100 Q 88,128 105,155 L 135,190 Q 148,208 135,225 L 105,258 Q 88,278 95,305 Q 98,310 110,312" fill="none" stroke="#d1d5db" stroke-width="22" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M 60,310 L 580,310 Q 630,310 630,265 Q 630,235 600,230 L 530,228 Q 510,228 510,210 Q 510,192 530,190 L 600,188 Q 640,185 640,150 Q 640,110 600,108 L 490,108 Q 460,108 445,128 L 420,158 Q 405,175 385,165 L 355,148 Q 335,138 335,118 Q 335,95 355,85 L 415,60 Q 440,48 440,28 Q 440,10 415,8 L 310,8 Q 285,8 270,25 L 240,58 Q 225,75 200,75 L 155,75 Q 120,75 105,100 Q 88,128 105,155 L 135,190 Q 148,208 135,225 L 105,258 Q 88,278 95,305 Q 98,310 110,312" fill="none" stroke="#e5e7eb" stroke-width="16" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M 60,310 L 580,310 Q 630,310 630,265 Q 630,235 600,230 L 530,228 Q 510,228 510,210 Q 510,192 530,190 L 600,188 Q 640,185 640,150 Q 640,110 600,108 L 490,108 Q 460,108 445,128 L 420,158 Q 405,175 385,165 L 355,148 Q 335,138 335,118 Q 335,95 355,85 L 415,60 Q 440,48 440,28 Q 440,10 415,8 L 310,8 Q 285,8 270,25 L 240,58 Q 225,75 200,75 L 155,75 Q 120,75 105,100 Q 88,128 105,155 L 135,190 Q 148,208 135,225 L 105,258 Q 88,278 95,305 Q 98,310 110,312" fill="none" stroke="#9ca3af" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
          <line x1="200" y1="326" x2="500" y2="326" stroke="#9ca3af" stroke-width="6"/>
          <rect x="388" y="302" width="5" height="30" fill="#111827"/>
          ${gerarStandsSVG(stands, oc)}
        </svg>
        <div id="stand-seats-panel" style="display:none;margin-top:12px;border-top:1px solid #e5e7eb;padding-top:12px;"></div>`;

        // Calcula total de lugares
        let total = 0;
