    // ── WINDOW.ONLOAD DINÂMICO ────────────────────────────────

    window.onload = function(){
        // CHAMADA NOVA: Buscar o preço real do Salesforce
        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.BilheteiraController.getPrecoBilhete}', evtId,
            function(result, event) {
                if (event.status) {
                    PRECO = result; // Atualiza a variável global com o valor do Pricebook
                    console.log('Preço atualizado do Salesforce:', PRECO);
                }
            }
        );
        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.BilheteiraController.getMapaConfig}', evtId,
            function(mapaJson){
                console.log('RAW:', mapaJson);
                if(mapaJson.startsWith('ERRO')){ alert(mapaJson); return; }

                const mapa = JSON.parse(decodeHtml(mapaJson));

                TIPO_MAPA = mapa.tipo;

                // Atualiza o label do palco
                const stageBar = document.querySelector('.stage-bar');
                if(stageBar) stageBar.innerText = mapa.palco;

                if(mapa.tipo === 'sba'){
                    // Super Bock Arena — grelha normal
                    ROWS_FRENTE  = mapa.filas_frente;
                    ROWS_TRAS    = mapa.filas_tras;
                    FRONT_BLOCKS = [];
                    mapa.blocos_frente.forEach((b, i) => {
                        FRONT_BLOCKS.push({z: b.zona, start: b.inicio, cols: b.colunas});
                        // adiciona aisles entre blocos
                        if(i === 1 || i === 3) FRONT_BLOCKS.push('lg');
                        else if(i < mapa.blocos_frente.length - 1) FRONT_BLOCKS.push('sm');
                    });
                    COLS_TRAS = mapa.colunas_tras;
                    ZONA_TRAS = mapa.zona_tras;

                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.BilheteiraController.getLugaresOcupados}', evtId,
                        function(ocupados){ construirMapa(ocupados || []); }
                    );

                } else if(mapa.tipo === 'aa'){
                    // Autódromo do Algarve — mapa de pista com stands
                    STANDS_AA = mapa.stands;

                    // Atualiza legenda dinamicamente
                    const legEl = document.querySelector('.map-legend');
                    if(legEl){
                        legEl.innerHTML = mapa.stands.map(s =>
                            `<div class="leg"><div class="ldot" style="background:${s.cor}"></div>${s.label.replace('Stand ','')}</div>`
                        ).join('') + '<div class="leg"><div class="ldot" style="background:#fbbf24;outline:1.5px solid #e5a000;outline-offset:1px;"></div>Selecionado</div>';
                    }

                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.BilheteiraController.getLugaresOcupados}', evtId,
                        function(ocupados){
                            ocupadosGlobal = new Set(ocupados || []);
                            construirMapaAutodromo(mapa.stands, ocupados || []);
                        }
                    );
                }else if(mapa.tipo === 'meoarena'){
                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.BilheteiraController.getLugaresOcupados}', evtId,
                        function(ocupados){
                            construirMapaMeoArena(mapa, ocupados || []);
                        }
                    );
                }else if(mapa.tipo === 'forumbraga'){
                    Visualforce.remoting.Manager.invokeAction(
                        '{!$RemoteAction.BilheteiraController.getLugaresOcupados}', evtId,
                        function(ocupados){
                            construirMapaForumBraga(mapa, ocupados || []);
                        }
                    );
                }
            }
        );
    };

    // ── STEPS E MODAL ─────────────────────────────────────────

    function switchStep(from, to){
        document.getElementById(from).classList.remove('active');
        document.getElementById(to).classList.add('active');
    }

    function irParaStep2(){
        if(selecionados.length === 0){ alert('Selecione pelo menos um lugar!'); return; }
        switchStep('step1','step2');
    }

    function abrirModal(){
        const total = (selecionados.length * PRECO).toFixed(2).replace('.',',');
        document.getElementById('modalChips').innerHTML = selecionados.map(s => {
            const label = s.stand
                ? `${s.stand.replace('-',' ')} · Fila ${s.fila} · Lugar ${s.lugar}`
                : `Fila ${s.fila} · Lugar ${s.lugar}`;
            return `<div class="chip"><div class="chip-dot"></div>${label}</div>`;
        }).join('');
        document.getElementById('mQtd').innerText       = selecionados.length;
        document.getElementById('mPrecoUnit').innerText = PRECO.toFixed(2).replace('.',',') + ' €';
        document.getElementById('mMetodo').innerText    = metodoAtual;
        document.getElementById('mTotal').innerText     = total + ' €';
        document.getElementById('btnModalPagar').style.background = TEMAS[metodoAtual].btnColor;
        document.getElementById('modalDetalhes').classList.add('open');
    }

    function fecharModal(){
        document.getElementById('modalDetalhes').classList.remove('open');
    }

    function confirmarECriar(){
    const btn = document.getElementById('btnModalPagar');
    btn.innerText = 'A processar...';
    btn.disabled = true;

    const nomeEl = document.getElementById('checkoutNome');
    const emailEl = document.getElementById('checkoutEmail');

    const nome = nomeEl ? nomeEl.value.trim() : '';
    const email = emailEl ? emailEl.value.trim() : '';

    if(!nome){
        alert('Introduza o nome.');
        btn.innerText = 'Pagar Agora';
        btn.disabled = false;
        return;
    }

    if(!email){
        alert('Introduza o email.');
        btn.innerText = 'Pagar Agora';
        btn.disabled = false;
        return;
    }

    Visualforce.remoting.Manager.invokeAction(
        '{!$RemoteAction.BilheteiraController.criarReserva}',
        evtId,
        accId || null,
        metodoAtual,
        nome,
        email,
        function(result, event){
            btn.innerText = 'Pagar Agora';
            btn.disabled = false;

            console.log('criarReserva result:', result);
            console.log('criarReserva event:', event);

            if(!event.status){
                alert('Erro de comunicação: ' + (event.message || 'sem detalhe'));
                return;
            }

            if(result === 'CLIENTE_INVALIDO'){
                fecharModal();
                alert('Cliente inválido.');
                return;
            }

            if(result === 'PAGAMENTO_RECUSADO'){
                fecharModal();
                alert('Pagamento recusado. Contacte o suporte para mais informações.');
                return;
            }

            if(result && result.indexOf('ERRO:') === 0){
                alert(result);
                return;
            }

            orderIdAtiva = result;
            fecharModal();
            aplicarTema(metodoAtual);

            const totalFmt = (selecionados.length * PRECO).toFixed(2).replace('.',',') + '€';
            document.getElementById('receipt-lugares').innerText = selecionados.map(s =>
                s.stand ? `${s.stand} ${s.fila}${s.lugar}` : `${s.fila}${s.lugar}`
            ).join(', ');
            document.getElementById('receipt-metodo').innerText  = metodoAtual;
            document.getElementById('total-display').innerText   = totalFmt;
            document.getElementById('trans-id').innerText        = result;

            if(metodoAtual === 'Referência'){
                const ref = Math.floor(Math.random()*900000000+100000000).toString();
                document.getElementById('mbRefNum').innerText = ref.slice(0,3)+' '+ref.slice(3,6)+' '+ref.slice(6);
                document.getElementById('mbRefVal').innerText = totalFmt;
                document.getElementById('mbRefBox').style.display = 'block';
            } else {
                document.getElementById('mbRefBox').style.display = 'none';
            }

            switchStep('step2','step3');
                    },
                    { escape: false }
                );
            }

    function finalizarTudo(){
        const btn = document.getElementById('btnFinal');
        btn.innerText = 'A PROCESSAR…'; btn.disabled = true;

        const payload = JSON.stringify(selecionados.map(s => ({
            fila:  s.fila,
            lugar: s.lugar,
            stand: s.stand || null
        })));

        Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.BilheteiraController.processarPagamentoMock}',
            orderIdAtiva, evtId, payload,
            function(res, event){
                btn.innerText = TEMAS[metodoAtual].btn; btn.disabled = false;
                if(!event.status){ alert('Erro de comunicação.'); return; }
                if(res === 'PAGAMENTO_RECUSADO'){
                    alert('Pagamento recusado. Contacte o suporte para mais informações.');
                    return;
                }
                if(res !== 'PAGAMENTO_OK'){ alert('Erro: ' + res); return; }
                switchStep('step3','step-success');
            },
            {escape:false}
        );
    }
