<apex:page standardController="Order" extensions="BilheteiraController" docType="html-5.0">
    <style>
        .container { max-width: 500px; margin: 40px auto; font-family: sans-serif; }
        .card { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border: 1px solid #eee; }
        .step { display: none; animation: fadeIn 0.4s; }
        .step.active { display: block; }
        .btn { width: 100%; padding: 15px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; margin-top: 15px; font-size: 16px; }
        .btn-primary { background: #007bff; color: white; }
        .btn-mbway { background: #e30613; color: white; }
        .bank-mock { background: #f4f4f4; border: 2px solid #ccc; padding: 20px; border-radius: 10px; }
        .input-group { margin-bottom: 15px; }
        input, select { width: 100%; padding: 12px; border-radius: 6px; border: 1px solid #ddd; box-sizing: border-box; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>

    <div class="container">
        <div id="step1" class="card step active">
            <h2>🎫 Passo 1: Lugares</h2>
            <div id="lista-lugares">
                <div class="input-group">
                    <input type="text" id="f-1" placeholder="Fila" style="width: 45%; display: inline-block;" />
                    <input type="number" id="l-1" placeholder="Lugar" style="width: 45%; display: inline-block; float: right;" />
                </div>
            </div>
            <button class="btn btn-primary" onclick="irParaStep2()">Próximo: Pagamento</button>
        </div>

        <div id="step2" class="card step">
            <h2>💳 Passo 2: Pagamento</h2>
            <p>Escolha como deseja pagar:</p>
            <select id="metodo">
                <option value="MBWay">📱 MBWay</option>
                <option value="Cartão">💳 Cartão de Crédito</option>
                <option value="Referência">🏦 Entidade e Referência</option>
            </select>
            <button class="btn btn-primary" onclick="irParaStep3()">Ir para Checkout</button>
            <button class="btn" onclick="voltar(1)" style="background:#ccc;">Voltar</button>
        </div>

        <div id="step3" class="card step">
            <div id="mock-banco" class="bank-mock">
                <h3 id="titulo-banco">Confirmar MBWay</h3>
                <p>Valor: <b id="valor-final">26,50 €</b></p>
                <p>ID Transação: <small id="trans-id">---</small></p>
                <hr/>
                <p style="font-size: 12px;">Esta é uma página segura de simulação.</p>
                <button class="btn btn-mbway" id="btnConfirmar" onclick="finalizarTudo()">CONFIRMAR PAGAMENTO</button>
            </div>
        </div>

        <div id="step-success" class="card step text-center" style="text-align:center;">
            <div style="font-size: 50px;">✅</div>
            <h2>Pago com Sucesso!</h2>
            <p>Obrigado! Os teus bilhetes foram emitidos.</p>
        </div>
    </div>

    <script>
        let orderIdCriada = '';

        function irParaStep2() {
            document.getElementById('step1').classList.remove('active');
            document.getElementById('step2').classList.add('active');
        }

        function irParaStep3() {
            const metodo = document.getElementById('metodo').value;
            const fila = document.getElementById('f-1').value;
            const lugar = document.getElementById('l-1').value;
            
            // Aqui chamamos o Apex para criar a reserva antes de mostrar o banco
            const bilhetes = JSON.stringify([{fila: fila, lugar: parseInt(lugar)}]);
            
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.BilheteiraController.criarReserva}',
                'a03d200001dzD7rAAE', '001d200001UmD61AAF', metodo, bilhetes,
                function(result, event) {
                    if (event.status && !result.startsWith('ERRO')) {
                        orderIdCriada = result;
                        document.getElementById('trans-id').innerText = result;
                        document.getElementById('titulo-banco').innerText = 'Checkout: ' + metodo;
                        document.getElementById('step2').classList.remove('active');
                        document.getElementById('step3').classList.add('active');
                    } else { alert(result); }
                }
            );
        }

        function finalizarTudo() {
            document.getElementById('btnConfirmar').disabled = true;
            document.getElementById('btnConfirmar').innerText = 'A processar...';

            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.BilheteiraController.processarPagamentoMock}',
                orderIdCriada,
                function(result) {
                    if(result === 'PAGAMENTO_OK') {
                        document.getElementById('step3').classList.remove('active');
                        document.getElementById('step-success').classList.add('active');
                    } else { alert(result); }
                }
            );
        }
    </script>
</apex:page>